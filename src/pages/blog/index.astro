---
import { getCollection } from "astro:content";

import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/Footer.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import Header from "@/components/Header.astro";
import Tag from "@/components/ui/Tag.astro";

interface BlogPost {
  data: {
    description: string;
    heroImage?: string;
    pubDate: Date;
    tags?: string[];
    title: string;
    updatedDate?: Date;
  };
  id: string;
}

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
) as BlogPost[];

// Extract unique tags from all posts
const allTags = [
  ...new Set(posts.flatMap((post: BlogPost) => post.data.tags || [])),
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      description="Thoughts on software engineering, web development, and continuous learning."
      title="Blog | Theoklitos Bampouris"
    />
  </head>
  <body class="grain-overlay">
    <Header />

    <main class="blog-main">
      <!-- Blog Header -->
      <section class="blog-hero">
        <div class="container-narrow">
          <div class="blog-hero-content">
            <span class="blog-label">Writing</span>
            <h1 class="blog-title">Thoughts & Insights</h1>
            <p class="blog-description">
              Exploring software engineering, web development best practices,
              and lessons learned from building digital products.
            </p>

            <!-- Filter Tags -->
            {
              allTags.length > 0 && (
                <div class="filter-tags">
                  <button class="filter-btn is-active" data-filter="all">
                    All
                  </button>
                  {allTags.map((tag) => (
                    <button class="filter-btn" data-filter={tag}>
                      {tag}
                    </button>
                  ))}
                </div>
              )
            }
          </div>
        </div>
      </section>

      <!-- Posts Grid -->
      <section class="blog-posts">
        <div class="container-wide">
          <div class="posts-masonry" id="postsGrid">
            {
              posts.map((post, index) => (
                <article
                  class={`post-item ${index === 0 ? "post-item-featured" : ""}`}
                  data-tags={post.data.tags?.join(",") || ""}
                >
                  <a class="post-link" href={`/blog/${post.id}/`}>
                    {post.data.heroImage && (
                      <div class="post-image">
                        <img
                          alt={`Cover image for ${post.data.title}`}
                          loading={index < 3 ? "eager" : "lazy"}
                          src={post.data.heroImage}
                        />
                        <div class="post-image-overlay" />
                      </div>
                    )}

                    <div class="post-content">
                      <div class="post-meta">
                        {post.data.tags && post.data.tags[0] && (
                          <Tag size="sm" variant="accent">
                            {post.data.tags[0]}
                          </Tag>
                        )}
                        <span class="post-date">
                          <svg
                            fill="none"
                            height="14"
                            stroke="currentColor"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                            width="14"
                          >
                            <rect
                              height="18"
                              rx="2"
                              ry="2"
                              width="18"
                              x="3"
                              y="4"
                            />
                            <line x1="16" x2="16" y1="2" y2="6" />
                            <line x1="8" x2="8" y1="2" y2="6" />
                            <line x1="3" x2="21" y1="10" y2="10" />
                          </svg>
                          <FormattedDate date={post.data.pubDate} />
                        </span>
                      </div>

                      <h2 class="post-title">{post.data.title}</h2>

                      <p class="post-excerpt">{post.data.description}</p>

                      <div class="post-footer">
                        <span class="read-more">
                          Read Article
                          <svg
                            fill="none"
                            height="16"
                            stroke="currentColor"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                            width="16"
                          >
                            <path d="M5 12h14" />
                            <path d="m12 5 7 7-7 7" />
                          </svg>
                        </span>
                        <span class="reading-time">
                          <svg
                            fill="none"
                            height="14"
                            stroke="currentColor"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                            width="14"
                          >
                            <circle cx="12" cy="12" r="10" />
                            <polyline points="12 6 12 12 16 14" />
                          </svg>
                          5 min read
                        </span>
                      </div>
                    </div>
                  </a>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <!-- Newsletter CTA -->
      <section class="blog-cta">
        <div class="container-narrow">
          <div class="cta-card">
            <div class="cta-content">
              <h2 class="cta-title">Stay Updated</h2>
              <p class="cta-description">
                Get notified when I publish new articles. No spam, unsubscribe
                anytime.
              </p>
              <form class="cta-form" onsubmit="(e) => e.preventDefault()">
                <input
                  aria-label="Email address"
                  class="cta-input"
                  placeholder="Enter your email"
                  required
                  type="email"
                />
                <button class="cta-button" type="submit">
                  Subscribe
                  <svg
                    fill="none"
                    height="16"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                    width="16"
                  >
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                  </svg>
                </button>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <Footer />

    <!-- Filter Script -->
    <script>
      const filterBtns: NodeListOf<HTMLElement> =
        document.querySelectorAll(".filter-btn");
      const postItems: NodeListOf<HTMLElement> =
        document.querySelectorAll(".post-item");

      filterBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          // Update active state
          filterBtns.forEach((b) => b.classList.remove("is-active"));
          btn.classList.add("is-active");

          const filter = btn.dataset.filter;

          // Filter posts
          postItems.forEach((item) => {
            const tags = item.dataset.tags || "";
            const shouldShow = filter === "all" || tags.includes(filter || "");

            if (shouldShow) {
              item.style.display = "";
              item.style.opacity = "0";
              item.style.transform = "translateY(20px)";
              setTimeout(() => {
                item.style.transition =
                  "opacity 0.4s ease, transform 0.4s ease";
                item.style.opacity = "1";
                item.style.transform = "translateY(0)";
              }, 50);
            } else {
              item.style.opacity = "0";
              item.style.transform = "translateY(20px)";
              setTimeout(() => {
                item.style.display = "none";
              }, 400);
            }
          });
        });
      });
    </script>
  </body>
</html>

<style>
  /* Main Container */
  .blog-main {
    padding-top: 80px; /* Account for fixed header */
  }

  /* Blog Hero */
  .blog-hero {
    padding: var(--space-20) 0 var(--space-12);
    text-align: center;
  }

  .blog-hero-content {
    max-width: 640px;
    margin: 0 auto;
  }

  .blog-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .blog-label::before {
    content: "";
    width: 24px;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), transparent);
  }

  .blog-title {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .blog-title {
      font-size: var(--text-6xl);
    }
  }

  .blog-description {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
    line-height: 1.7;
  }

  /* Filter Tags */
  .filter-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
  }

  .filter-btn {
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    background: var(--color-bg-secondary);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-btn:hover {
    background: var(--color-bg-tertiary);
    color: var(--color-text-primary);
  }

  .filter-btn.is-active {
    background: var(--color-accent);
    color: white;
  }

  /* Blog Posts Section */
  .blog-posts {
    padding: var(--space-8) 0 var(--space-16);
  }

  /* Masonry Grid */
  .posts-masonry {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .posts-masonry {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .posts-masonry {
      grid-template-columns: repeat(3, 1fr);
    }

    .post-item-featured {
      grid-column: span 2;
      grid-row: span 2;
    }
  }

  /* Post Item */
  .post-item {
    transition:
      transform 0.4s ease,
      opacity 0.4s ease;
  }

  .post-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-bg-primary);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.05);
    text-decoration: none;
    transition: box-shadow var(--transition-base);
  }

  @media (prefers-color-scheme: dark) {
    .post-link {
      border-color: rgba(255, 255, 255, 0.05);
    }
  }

  .post-link:hover {
    box-shadow: var(--box-shadow);
  }

  /* Post Image */
  .post-image {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .post-item-featured .post-image {
    aspect-ratio: 16 / 9;
  }

  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-link:hover .post-image img {
    transform: scale(1.05);
  }

  .post-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(0, 0, 0, 0.3) 100%
    );
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .post-link:hover .post-image-overlay {
    opacity: 1;
  }

  /* Post Content */
  .post-content {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-item-featured .post-content {
    padding: var(--space-8);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .post-date {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-3);
    line-height: 1.3;
    transition: color var(--transition-fast);
  }

  .post-item-featured .post-title {
    font-size: var(--text-3xl);
  }

  .post-link:hover .post-title {
    color: var(--color-accent);
  }

  .post-excerpt {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0 0 var(--space-6) 0;
    flex: 1;
  }

  /* Post Footer */
  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-bg-secondary);
  }

  .read-more {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--color-accent);
    transition: gap var(--transition-fast);
  }

  .post-link:hover .read-more {
    gap: var(--space-3);
  }

  .read-more svg {
    transition: transform var(--transition-fast);
  }

  .post-link:hover .read-more svg {
    transform: translateX(4px);
  }

  .reading-time {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  /* Blog CTA */
  .blog-cta {
    padding: var(--space-16) 0;
  }

  .cta-card {
    background: linear-gradient(
      135deg,
      var(--color-bg-secondary) 0%,
      rgba(37, 99, 235, 0.05) 100%
    );
    border-radius: var(--radius-2xl);
    padding: var(--space-12) var(--space-8);
    text-align: center;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  @media (prefers-color-scheme: dark) {
    .cta-card {
      background: linear-gradient(
        135deg,
        var(--color-bg-tertiary) 0%,
        rgba(37, 99, 235, 0.1) 100%
      );
      border-color: rgba(255, 255, 255, 0.05);
    }
  }

  .cta-content {
    max-width: 480px;
    margin: 0 auto;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--space-3);
  }

  .cta-description {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .cta-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  @media (min-width: 480px) {
    .cta-form {
      flex-direction: row;
    }
  }

  .cta-input {
    flex: 1;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    background: var(--color-bg-primary);
    border: 1px solid var(--color-bg-secondary);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-fast);
  }

  .cta-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .cta-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-base);
    color: white;
    background: var(--color-accent);
    border: none;
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: all var(--transition-spring);
    white-space: nowrap;
  }

  .cta-button:hover {
    background: var(--accent-dark);
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(37, 99, 235, 0.3);
  }

  .cta-button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .cta-button svg {
    transition: transform var(--transition-fast);
  }

  .cta-button:hover svg {
    transform: translateX(4px);
  }
</style>
