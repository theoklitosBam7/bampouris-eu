---
const today = new Date();

const footerLinks = [
  {
    links: [
      { external: false, href: "/", label: "Home" },
      { external: false, href: "/blog", label: "Blog" },
    ],
    title: "Navigation",
  },
  {
    links: [
      {
        external: true,
        href: "https://github.com/theoklitosBam7",
        label: "GitHub",
      },
      {
        external: true,
        href: "https://linkedin.com/in/theoklitosbam7",
        label: "LinkedIn",
      },
      {
        external: true,
        href: "https://x.com/theoklitosBam7",
        label: "X",
      },
    ],
    title: "Connect",
  },
];

const socialLinks = [
  {
    href: "https://github.com/theoklitosBam7",
    icon: "github",
    label: "GitHub",
  },
  {
    href: "https://linkedin.com/in/theoklitosbam7",
    icon: "linkedin",
    label: "LinkedIn",
  },
  {
    href: "https://x.com/theoklitosBam7",
    icon: "x",
    label: "X",
  },
];
---

<footer class="footer">
  <div class="footer-container">
    <!-- Top Section -->
    <div class="footer-top">
      <!-- Brand -->
      <div class="footer-brand">
        <a class="footer-logo" href="/">
          <span class="footer-logo-mark">TB</span>
          <span class="footer-logo-text">Theoklitos Bampouris</span>
        </a>
        <p class="footer-tagline">
          Software Engineer crafting digital experiences that matter.
        </p>

        <!-- Social Links -->
        <div class="footer-social">
          {
            socialLinks.map((link) => (
              <a
                aria-label={`Follow on ${link.label}`}
                class="footer-social-link"
                href={link.href}
                rel="noopener noreferrer"
                target="_blank"
              >
                {link.icon === "github" ? (
                  <svg
                    fill="none"
                    height="20"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                    width="20"
                  >
                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                    <path d="M9 18c-4.51 2-5-2-7-2" />
                  </svg>
                ) : link.icon === "x" ? (
                  <svg
                    fill="currentColor"
                    height="20"
                    viewBox="0 0 24 24"
                    width="20"
                  >
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                  </svg>
                ) : (
                  <svg
                    fill="none"
                    height="20"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                    width="20"
                  >
                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                    <rect height="12" width="4" x="2" y="9" />
                    <circle cx="4" cy="4" r="2" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Link Columns -->
      <div class="footer-links">
        {
          footerLinks.map((column) => (
            <div class="footer-column">
              <h3 class="footer-column-title">{column.title}</h3>
              <ul class="footer-column-list">
                {column.links.map((link) => (
                  <li class="footer-column-item">
                    <a
                      class="footer-column-link"
                      href={link.href}
                      rel={link.external ? "noopener noreferrer" : undefined}
                      target={link.external ? "_blank" : undefined}
                    >
                      {link.label}
                      {link.external && (
                        <svg
                          class="external-icon"
                          fill="none"
                          height="12"
                          stroke="currentColor"
                          stroke-width="2"
                          viewBox="0 0 24 24"
                          width="12"
                        >
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                          <polyline points="15 3 21 3 21 9" />
                          <line x1="10" x2="21" y1="14" y2="3" />
                        </svg>
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; {today.getFullYear()} Theoklitos Bampouris. All rights reserved.
      </p>
      <p class="footer-credit">
        Built with <a
          href="https://astro.build"
          rel="noopener noreferrer"
          target="_blank">Astro</a
        >
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-secondary);
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    padding: var(--space-16) 0 var(--space-8);
    margin-top: auto;
  }

  @media (prefers-color-scheme: dark) {
    .footer {
      background-color: var(--color-bg-tertiary);
      border-top-color: rgba(255, 255, 255, 0.05);
    }
  }

  .footer-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  /* Top Section */
  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .footer-top {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  /* Brand */
  .footer-brand {
    max-width: 320px;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
    transition: opacity var(--transition-fast);
  }

  .footer-logo:hover {
    opacity: 0.7;
  }

  .footer-logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: linear-gradient(
      135deg,
      var(--color-accent),
      var(--color-accent-warm)
    );
    color: white;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-xs);
    border-radius: var(--radius-md);
  }

  .footer-logo-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-lg);
  }

  .footer-tagline {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
    line-height: 1.6;
  }

  /* Social Links */
  .footer-social {
    display: flex;
    gap: var(--space-3);
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-text-secondary);
    background-color: var(--color-bg-primary);
    border-radius: var(--radius-full);
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .footer-social-link:hover {
    color: var(--color-accent);
    background-color: rgba(37, 99, 235, 0.1);
    transform: translateY(-2px);
  }

  /* Link Columns */
  .footer-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .footer-links {
      display: contents;
    }
  }

  .footer-column-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-4);
  }

  .footer-column-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-column-item {
    margin-bottom: var(--space-3);
  }

  .footer-column-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-column-link:hover {
    color: var(--color-accent);
  }

  .external-icon {
    opacity: 0.5;
  }

  /* Bottom Section */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-8);
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  @media (prefers-color-scheme: dark) {
    .footer-bottom {
      border-top-color: rgba(255, 255, 255, 0.05);
    }
  }

  .footer-copyright {
    margin: 0;
  }

  .footer-credit {
    margin: 0;
  }

  .footer-credit a {
    color: var(--color-text-secondary);
  }

  .footer-credit a:hover {
    color: var(--color-accent);
  }
</style>
