---
interface Props {
  class?: string;
  href?: string;
  size?: "md" | "sm";
  variant?: "accent" | "default" | "ghost" | "outline";
}

const {
  class: className = "",
  href,
  size = "sm",
  variant = "default",
} = Astro.props;

const baseClasses = "tag";
const variantClass = `tag-${variant}`;
const sizeClass = `tag-${size}`;
const allClasses =
  `${baseClasses} ${variantClass} ${sizeClass} ${className}`.trim();
---

{
  href ? (
    <a class={allClasses} href={href}>
      <slot />
    </a>
  ) : (
    <span class={allClasses}>
      <slot />
    </span>
  )
}

<style>
  /* Base Tag Styles */
  .tag {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-mono);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-full);
    transition: all var(--transition-fast);
    text-decoration: none;
  }

  /* Size Variants */
  .tag-sm {
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
  }

  .tag-md {
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-sm);
  }

  /* Default Variant */
  .tag-default {
    background-color: var(--color-bg-secondary);
    color: var(--color-text-secondary);
  }

  .tag-default:hover {
    background-color: var(--color-accent);
    color: white;
  }

  /* Accent Variant */
  .tag-accent {
    background-color: rgba(37, 99, 235, 0.1);
    color: var(--color-accent);
  }

  .tag-accent:hover {
    background-color: var(--color-accent);
    color: white;
  }

  /* Outline Variant */
  .tag-outline {
    background-color: transparent;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-bg-secondary);
  }

  .tag-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Ghost Variant */
  .tag-ghost {
    background-color: transparent;
    color: var(--color-text-tertiary);
    padding-left: 0;
    padding-right: 0;
  }

  .tag-ghost:hover {
    color: var(--color-text-primary);
  }

  /* Link Tag Styles */
  a.tag {
    cursor: pointer;
  }

  /* Active/Current State */
  .tag.is-active {
    background-color: var(--color-accent);
    color: white;
  }

  /* Dark Mode Adjustments */
  @media (prefers-color-scheme: dark) {
    .tag-default {
      background-color: var(--color-bg-tertiary);
    }

    .tag-outline {
      border-color: var(--color-bg-tertiary);
    }
  }

  /* Tag with Icon */
  .tag svg {
    width: 12px;
    height: 12px;
  }

  /* Tag Group */
  .tag-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* Filter Tag (for blog filtering) */
  .tag-filter {
    cursor: pointer;
    user-select: none;
  }

  .tag-filter input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .tag-filter input:checked + .tag {
    background-color: var(--color-accent);
    color: white;
  }
</style>
