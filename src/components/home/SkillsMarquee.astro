---
// Tech stack icons - using SVGs for consistency
const technologies = [
  { icon: "react", name: "React" },
  { icon: "typescript", name: "TypeScript" },
  { icon: "vue", name: "Vue" },
  { icon: "nodejs", name: "Node.js" },
  { icon: "astro", name: "Astro" },
  { icon: "tailwind", name: "Tailwind CSS" },
  { icon: "git", name: "Git" },
  { icon: "docker", name: "Docker" },
  { icon: "nextjs", name: "Next.js" },
  { icon: "python", name: "Python" },
];

// Duplicate for seamless loop
const allTechnologies = [...technologies, ...technologies];
---

<section class="section" id="skills">
  <div class="container-wide">
    <!-- Section Header -->
    <div class="section-header reveal-on-scroll">
      <span class="section-label">Tech Stack</span>
      <h2 class="section-title">Technologies I Work With</h2>
      <p class="section-description">
        A curated selection of tools and technologies I use to build modern,
        scalable web applications.
      </p>
    </div>

    <!-- Marquee Container -->
    <div class="marquee-container reveal-on-scroll">
      <div class="marquee">
        <div class="marquee-content">
          {
            allTechnologies.map((tech) => (
              <div class="tech-card">
                <div class="tech-icon">
                  {tech.icon === "react" && (
                    <svg
                      fill="currentColor"
                      viewBox="-11.5 -10.23174 23 20.46348"
                    >
                      <circle cx="0" cy="0" fill="currentColor" r="2.05" />
                      <g fill="none" stroke="currentColor" stroke-width="1">
                        <ellipse rx="11" ry="4.2" />
                        <ellipse rx="11" ry="4.2" transform="rotate(60)" />
                        <ellipse rx="11" ry="4.2" transform="rotate(120)" />
                      </g>
                    </svg>
                  )}
                  {tech.icon === "typescript" && (
                    <svg fill="currentColor" viewBox="0 0 24 24">
