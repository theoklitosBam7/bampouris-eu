        </div>
        <h3 class="bento-title">Performance</h3>
        <p class="bento-description">
          Optimizing for speed, accessibility, and user experience.
        </p>
      </div>
      <div class="bento-card">
        <div class="bento-icon">
          <svg
            fill="none"
            height="24"
            stroke="currentColor"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="24"
          >
            <path d="m8 3 4 8 5-5 5 15H2L8 3z"></path>
          </svg>
        </div>
        <h3 class="bento-title">Modern Stack</h3>
        <p class="bento-description">
          Working with cutting-edge technologies and best practices.
        </p>
      </div>
