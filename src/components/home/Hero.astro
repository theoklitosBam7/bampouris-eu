---
import { Image } from "astro:assets";

import Button from "@/components/ui/Button.astro";
---

<section class="hero" id="hero">
  <!-- Background Effects -->
  <div class="hero-bg">
    <div class="gradient-orb orb-1"></div>
    <div class="gradient-orb orb-2"></div>
    <div class="gradient-orb orb-3"></div>
    <div class="grid-pattern"></div>
  </div>

  <div class="hero-container">
    <!-- Content Column -->
    <div class="hero-content">
      <!-- Label -->
      <div class="hero-label reveal-delay-1">
        <span class="label-line"></span>
        <span class="label-text">Software Engineer</span>
      </div>

      <!-- Headline -->
      <h1 class="hero-headline reveal-delay-2">
        Crafting
        <span class="text-gradient">digital experiences</span>
        that matter
      </h1>

      <!-- Subheadline -->
      <p class="hero-subheadline reveal-delay-3">
        Passionate about front-end web development with expertise in analysis,
        design, and implementation of cutting-edge web applications. Based in
        Greece.
      </p>

      <!-- Status Badge -->
      <div class="hero-status reveal-delay-3">
        <span class="status-dot"></span>
        <span class="status-text">Available for freelance projects</span>
      </div>

      <!-- CTA Buttons -->
      <div class="hero-ctas reveal-delay-4">
        <Button
          external
          href="https://github.com/theoklitosBam7"
          variant="primary"
        >
          <svg
            fill="none"
            height="20"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="20"
          >
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            ></path>
            <path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
          View GitHub
        </Button>
        <Button
          external
          href="https://linkedin.com/in/theoklitosbam7"
          variant="secondary"
        >
          <svg
            fill="none"
            height="20"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="20"
          >
            <path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
            ></path>
            <rect height="12" width="4" x="2" y="9"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
          LinkedIn
        </Button>
        <Button
          external
          href="https://x.com/theoklitosBam7"
          variant="secondary"
        >
          <svg fill="currentColor" height="20" viewBox="0 0 24 24" width="20">
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            ></path>
          </svg>
          Follow on X
        </Button>
      </div>

      <!-- Stats -->
      <div class="hero-stats reveal-delay-5">
        <div class="stat">
          <span class="stat-value">6+</span>
          <span class="stat-label">Years Experience</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">∞</span>
          <span class="stat-label">Cups of Coffee</span>
        </div>
      </div>
    </div>

    <!-- Visual Column -->
    <div class="hero-visual reveal-delay-2">
      <div class="avatar-container">
        <!-- Decorative Shapes -->
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>

        <!-- Avatar -->
        <div class="avatar-wrapper">
          <Image
            alt="Theoklitos Bampouris - Software Engineer"
            class="avatar"
            decoding="async"
            height={400}
            loading="eager"
            src="/avatar-anime-1.jpg"
            width={400}
          />
          <div class="avatar-glow"></div>
        </div>

        <!-- Floating Badge -->
        <div class="floating-badge badge-1">
          <span class="badge-icon">⚡</span>
          <span class="badge-text">Fast</span>
        </div>
        <div class="floating-badge badge-2">
          <span class="badge-icon">🎨</span>
          <span class="badge-text">Creative</span>
        </div>
        <div class="floating-badge badge-3">
          <span class="badge-icon">🚀</span>
          <span class="badge-text">Modern</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="scroll-indicator">
    <div class="scroll-mouse">
      <div class="scroll-wheel"></div>
    </div>
    <span class="scroll-text">Scroll to explore</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: var(--space-24) 0;
    overflow: hidden;
  }

  /* Background Effects */
  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .gradient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
    animation: float 20s ease-in-out infinite;
  }

  .orb-1 {
    width: 600px;
    height: 600px;
    background: linear-gradient(135deg, #2563eb, #3b82f6);
    top: -200px;
    right: -100px;
    animation-delay: 0s;
  }

  .orb-2 {
    width: 400px;
    height: 400px;
    background: linear-gradient(135deg, #f59e0b, #fbbf24);
    bottom: 10%;
    left: -100px;
    animation-delay: -7s;
  }

  .orb-3 {
    width: 300px;
    height: 300px;
    background: linear-gradient(135deg, #10b981, #34d399);
    top: 40%;
    right: 20%;
    animation-delay: -14s;
  }

  .grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(0, 0, 0, 0.03) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(0, 0, 0, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  @media (prefers-color-scheme: dark) {
    .grid-pattern {
      background-image:
        linear-gradient(
          to right,
          rgba(255, 255, 255, 0.03) 1px,
          transparent 1px
        ),
        linear-gradient(
          to bottom,
          rgba(255, 255, 255, 0.03) 1px,
          transparent 1px
        );
    }
  }

  /* Container */
  .hero-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 var(--space-6);
    position: relative;
    z-index: 1;
    width: 100%;
  }

  @media (min-width: 1024px) {
    .hero-container {
      grid-template-columns: 1.2fr 1fr;
      align-items: center;
    }
  }

  /* Content Column */
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    min-height: 0;
  }

  /* Label */
  .hero-label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
  }

  .label-line {
    width: 40px;
    height: 2px;
    background: linear-gradient(
      90deg,
      var(--color-accent-warm),
      var(--color-accent)
    );
  }

  .label-text {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
  }

  /* Headline */
  .hero-headline {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
  }

  @media (min-width: 768px) {
    .hero-headline {
      font-size: var(--text-6xl);
    }
  }

  @media (min-width: 1280px) {
    .hero-headline {
      font-size: var(--text-7xl);
    }
  }

  .hero-headline .text-gradient {
    background: linear-gradient(
      135deg,
      var(--color-accent) 0%,
      var(--color-accent-warm) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Subheadline */
  .hero-subheadline {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    max-width: 540px;
    line-height: 1.7;
    margin: 0;
  }

  /* Status Badge */
  .hero-status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background-color: rgba(16, 185, 129, 0.1);
    border-radius: var(--radius-full);
    width: fit-content;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background-color: var(--color-success);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
      box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
    }
    50% {
      opacity: 0.8;
      box-shadow: 0 0 0 8px rgba(16, 185, 129, 0);
    }
  }

  .status-text {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-success);
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  /* Stats */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin-top: auto;
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-bg-secondary);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background-color: var(--color-bg-secondary);
  }

  @media (max-width: 640px) {
    .hero-stats {
      gap: var(--space-4);
    }

    .stat-divider {
      display: none;
    }

    .stat {
      text-align: center;
    }
  }

  /* Visual Column */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .avatar-container {
    position: relative;
    width: 320px;
    height: 320px;
  }

  @media (min-width: 640px) {
    .avatar-container {
      width: 400px;
      height: 400px;
    }
  }

  @media (min-width: 1280px) {
    .avatar-container {
      width: 480px;
      height: 480px;
    }
  }

  /* Decorative Shapes */
  .shape {
    position: absolute;
    border-radius: var(--radius-2xl);
    opacity: 0.6;
    animation: float 8s ease-in-out infinite;
  }

  .shape-1 {
    width: 120px;
    height: 120px;
    background: linear-gradient(135deg, var(--color-accent), transparent);
    top: 0;
    left: 0;
    animation-delay: 0s;
  }

  .shape-2 {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--color-accent-warm), transparent);
    bottom: 20%;
    right: 0;
    animation-delay: -3s;
  }

  .shape-3 {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, var(--color-success), transparent);
    top: 30%;
    right: -5%;
    animation-delay: -6s;
  }

  /* Avatar */
  .avatar-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-bg-secondary), white);
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.25),
      0 0 0 1px rgba(255, 255, 255, 0.1) inset;
  }

  .avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .avatar-wrapper:hover .avatar {
    transform: scale(1.05);
  }

  .avatar-glow {
    position: absolute;
    inset: -10px;
    background: linear-gradient(
      135deg,
      var(--color-accent),
      var(--color-accent-warm)
    );
    border-radius: 50%;
    opacity: 0.15;
    filter: blur(30px);
    z-index: -1;
    animation: pulse-glow 4s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%,
    100% {
      opacity: 0.15;
      transform: scale(1);
    }
    50% {
      opacity: 0.25;
      transform: scale(1.05);
    }
  }

  /* Floating Badges */
  .floating-badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    border-radius: var(--radius-full);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-primary);
    animation: float-badge 6s ease-in-out infinite;
  }

  @media (prefers-color-scheme: dark) {
    .floating-badge {
      background: rgba(30, 30, 30, 0.9);
    }
  }

  .badge-1 {
    top: 10%;
    right: -5%;
    animation-delay: 0s;
  }

  .badge-2 {
    bottom: 25%;
    left: -10%;
    animation-delay: -2s;
  }

  .badge-3 {
    bottom: 5%;
    right: 10%;
    animation-delay: -4s;
  }

  .badge-icon {
    font-size: var(--text-lg);
  }

  @keyframes float-badge {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @media (max-width: 640px) {
    .floating-badge {
      display: none;
    }
  }

  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    opacity: 0.6;
    animation: fade-in-up 1s ease-out 1.5s both;
  }

  .scroll-mouse {
    width: 24px;
    height: 40px;
    border: 2px solid var(--color-text-tertiary);
    border-radius: var(--radius-full);
    position: relative;
  }

  .scroll-wheel {
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 8px;
    background-color: var(--color-text-tertiary);
    border-radius: var(--radius-full);
    animation: scroll-wheel 2s ease-in-out infinite;
  }

  @keyframes scroll-wheel {
    0%,
    100% {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    50% {
      opacity: 0.3;
      transform: translateX(-50%) translateY(8px);
    }
  }

  .scroll-text {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary);
  }

  @media (max-width: 768px) {
    .scroll-indicator {
      display: none;
    }
  }

  /* Reveal Animations */
  .reveal-delay-1,
  .reveal-delay-2,
  .reveal-delay-3,
  .reveal-delay-4,
  .reveal-delay-5 {
    opacity: 0;
    transform: translateY(24px);
    animation: reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .reveal-delay-1 {
    animation-delay: 0.1s;
  }
  .reveal-delay-2 {
    animation-delay: 0.2s;
  }
  .reveal-delay-3 {
    animation-delay: 0.3s;
  }
  .reveal-delay-4 {
    animation-delay: 0.4s;
  }
  .reveal-delay-5 {
    animation-delay: 0.5s;
  }

  @keyframes reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .gradient-orb,
    .shape,
    .floating-badge,
    .scroll-wheel,
    .avatar-glow {
      animation: none;
    }

    .reveal-delay-1,
    .reveal-delay-2,
    .reveal-delay-3,
    .reveal-delay-4,
    .reveal-delay-5 {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .scroll-indicator {
      animation: none;
    }
  }
</style>

<script>
  // Parallax effect for avatar on mouse move
  const avatarWrapper = document.querySelector(".avatar-wrapper");
  const hero = document.getElementById("hero");

  if (
    avatarWrapper &&
    hero &&
    !window.matchMedia("(pointer: coarse)").matches
  ) {
    hero.addEventListener("mousemove", (e) => {
      const rect = hero.getBoundingClientRect();
      const x = (e.clientX - rect.left - rect.width / 2) / rect.width;
      const y = (e.clientY - rect.top - rect.height / 2) / rect.height;

      const rotateX = y * -10;
      const rotateY = x * 10;

      (avatarWrapper as HTMLElement).style.transform =
        `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
    });

    hero.addEventListener("mouseleave", () => {
      (avatarWrapper as HTMLElement).style.transform =
        "perspective(1000px) rotateX(0) rotateY(0)";
    });
  }
</script>
